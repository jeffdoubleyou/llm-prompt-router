# LLM Prompt Router Environment Configuration
# Copy this file to .env and adjust values for your environment.

# Application server port (backend API)
APP_PORT=8001

# UI server port (frontend)
UI_PORT=80

# Database connection (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://router:router@db:5432/router
DATABASE_URL_SYNC=postgresql://router:router@db:5432/router

# Redis connection
REDIS_URL=redis://redis:6379/0

# Encryption key for signing tokens (generate a secure random key)
ENCRYPTION_KEY=change-me-to-a-secure-random-key

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Upstream API timeout in seconds (global default; per-model overrides available)
UPSTREAM_TIMEOUT=120.0
